<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.recycle.dao.GeneralDao">

    <select id="findByUserId" parameterType="string" resultType="com.example.recycle.dto.MemberDto">

    SELECT user_id AS id, password, name
    FROM member
    WHERE user_id = #{userId}

</select>

</mapper>