<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.recycle.dao.GeneralDao">

    <select id="findByUserId" parameterType="string" resultType="com.example.recycle.dto.UserDto">
        SELECT id, password, name
        FROM user
        WHERE id = #{userId}
    </select>

    <insert id="join" parameterType="com.example.recycle.dto.UserDto">
        INSERT INTO user(id, password, name)
        VALUES (#{id}, #{password}, #{name})
    </insert>
</mapper>